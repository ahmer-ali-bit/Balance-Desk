rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Linked Invites (Used for QR/Token sharing)
    match /linked_invites/{inviteToken} {
      allow read, write: if true;
    }

    // 2. Linked Sessions (Used for active device links)
    match /linked_sessions/{sessionId} {
      allow read, write: if true;
    }

    // 3. Workspace Snapshots (Used for cross-device sync)
    match /workspace_snapshots/{deviceId} {
      allow read, write: if true;
    }

    // Keep legacy collections for backward compatibility
    match /devices_v2/{deviceId} { allow read, write: if true; }
    match /linkedSessions_v2/{sessionId} { allow read, write: if true; }
    match /inviteLinks_v2/{linkToken} { allow read, write: if true; }
    
    // Default Deny
    match /{path=**} {
       allow read, write: if false; 
    }
  }
}
